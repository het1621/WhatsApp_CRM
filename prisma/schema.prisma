generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?

  // WhatsApp credentials (each user has own)
  whatsappPhoneNumberId  String?
  whatsappAccessToken    String?  // MUST be encrypted in production
  whatsappAppSecret      String?
  whatsappWabaId         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  contacts   Contact[]
  templates  Template[]
  campaigns  Campaign[]
  messageLogs MessageLog[]
}

model Contact {
  id        String   @id @default(uuid())
  userId    String
  phone     String
  name      String?
  status    String   @default("active") // active, opted_out, invalid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Unique per user, not globally
  @@unique([userId, phone])

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  MessageLog MessageLog[]
}

model Template {
  id         String   @id @default(uuid())
  userId     String
  name       String
  language   String
  status     String   @default("approved")
  components Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Unique per user, not globally
  @@unique([userId, name])

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  Campaign Campaign[]
}

model Campaign {
  id          String    @id @default(uuid())
  userId      String
  name        String
  templateId  String
  status      String    @default("draft") // draft, scheduled, running, completed, partial_failed, failed
  scheduledAt DateTime?

  // Campaign stats tracking (Phase 1)
  totalMessages   Int   @default(0)
  sentMessages    Int   @default(0)
  failedMessages  Int   @default(0)
  deliveredCount  Int   @default(0)
  failedCount     Int   @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  template   Template     @relation(fields: [templateId], references: [id])
  MessageLog MessageLog[]
}

model MessageLog {
  id         String   @id @default(uuid())
  userId     String
  contactId  String
  campaignId String?
  wamid      String?  @unique // Meta message ID
  status     String   @default("pending") // pending, sent, delivered, read, failed
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact  Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}
